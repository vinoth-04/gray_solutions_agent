{
  "id": "medvoice",
  "realm": "medvoice",
  "displayName": "MedVoice Dashboard",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 3600,
  "accessCodeLifespan": 60,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "medvoice-dashboard",
      "name": "MedVoice Dashboard",
      "enabled": true,
      "redirectUris": [
        "http://localhost:4000/*",
        "http://127.0.0.1:4000/*"
      ],
      "webOrigins": [
        "http://localhost:4000",
        "http://127.0.0.1:4000"
      ],
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "bearerOnly": false,
      "fullScopeAllowed": true,
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4000/*##http://127.0.0.1:4000/*"
      },
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "email",
        "roles"
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "email": "admin@medvoice.ai",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ]
    },
    {
      "username": "viewer",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Viewer",
      "lastName": "User",
      "email": "viewer@medvoice.ai",
      "credentials": [
        {
          "type": "password",
          "value": "viewer123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "viewer"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrator",
        "composite": false
      },
      {
        "name": "viewer",
        "description": "Read-only viewer",
        "composite": false
      }
    ]
  },
  "defaultDefaultClientScopes": [
    "role_list",
    "profile",
    "email",
    "roles",
    "web-origins",
    "acr"
  ]
}